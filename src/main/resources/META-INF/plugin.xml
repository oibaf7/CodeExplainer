<idea-plugin>
    <id>com.codeexplainer.CodeExplainer</id>
    <name>CodeExplainer</name>

    <vendor url="https://github.com/oibaf7">Fabio</vendor>

    <description><![CDATA[
        Explains code snippets using a local LLM via Ollama.
        Select code in the editor and get an instant explanation in the tool window.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="CodeExplainer"
                anchor="right"
                factoryClass="com.codeexplainer.ui.CodeExplainerWindowFactory"/>
        <applicationService
                serviceImplementation="com.codeexplainer.core.AppSettings"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.codeexplainer.ui.AppSettingsConfigurable"
                id="com.codeexplainer.ui.AppSettingsConfigurable"
                displayName="CodeExplainer Settings"/>
    </extensions>
    <actions>
        <action id="com.codeexplainer.ui.ExplainAction"
                class="com.codeexplainer.ui.ExplainAction"
                text="Explain Code"
                description="Explain the selected code using a local LLM">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>